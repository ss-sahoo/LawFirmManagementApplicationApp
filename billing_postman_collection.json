      "item": [
        {
          "name": "Create Time Entry",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Token {{auth_token}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"case\": \"{{case_id}}\",\n  \"date\": \"2024-05-15\",\n  \"activity_type\": \"court_appearance\",\n  \"description\": \"Attended hearing at District Court\",\n  \"hours\": 3.5,\n  \"hourly_rate\": 5000,\n  \"billable\": true,\n  \"status\": \"draft\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/billing/time-entries/",
              "host": ["{{base_url}}"],
              "path": ["api", "billing", "time-entries", ""]
            },
            "description": "Create a new time entry. Activity types: consultation, research, drafting, court_appearance, meeting, phone_call, email, review, travel, other"
          }
        },
        {
          "name": "List Time Entries",
          "request": {
            "method": "GET",
